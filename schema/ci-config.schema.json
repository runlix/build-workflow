{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runlix CI Config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "image": {
      "type": "string",
      "pattern": "^ghcr\\.io/runlix/[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "tag": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "arch": {
            "type": "string",
            "enum": [
              "amd64",
              "arm64"
            ]
          },
          "dockerfile": {
            "type": "string",
            "minLength": 1
          },
          "base_ref": {
            "type": "string",
            "pattern": "^.+:.+@sha256:[a-f0-9]{64}$"
          },
          "test": {
            "type": "string",
            "default": ""
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "build_args": {
            "type": "object",
            "patternProperties": {
              "^[A-Z_][A-Z0-9_]*$": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "name",
          "tag",
          "arch",
          "dockerfile",
          "base_ref"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "image",
    "targets"
  ],
  "additionalProperties": false
}
