{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runlix Build Config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "image": {
      "type": "string",
      "pattern": "^ghcr\\.io/runlix/[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "properties": {
        "context": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "build_args": {
          "type": "object",
          "patternProperties": {
            "^[A-Z_][A-Z0-9_]*$": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "manifest_tag": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "platform": {
            "type": "string",
            "enum": [
              "linux/amd64",
              "linux/arm64"
            ]
          },
          "dockerfile": {
            "type": "string",
            "minLength": 1
          },
          "test": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "build_args": {
            "type": "object",
            "patternProperties": {
              "^[A-Z_][A-Z0-9_]*$": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "name",
          "manifest_tag",
          "platform",
          "dockerfile"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "image",
    "targets"
  ],
  "additionalProperties": false
}
