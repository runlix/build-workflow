{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update distroless upstream image references",
      "managerFilePatterns": [
        "/^examples\\/build-config\\/base-image\\.json$/",
        "/^test-fixtures\\/ci\\/base-image\\/\\.ci\\/build\\.json$/",
        "/^test-fixtures\\/ci\\/service\\/\\.ci\\/build\\.json$/"
      ],
      "matchStrings": [
        "\"BASE_REF\"\\s*:\\s*\"gcr\\.io/distroless/base-debian12:(?<currentValue>[^@\\\"]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "depNameTemplate": "gcr.io/distroless/base-debian12",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update distroless runtime base refs",
      "managerFilePatterns": [
        "/^examples\\/build-config\\/service-image\\.json$/"
      ],
      "matchStrings": [
        "\"BASE_REF\"\\s*:\\s*\"ghcr\\.io/runlix/distroless-runtime:(?<currentValue>[^@\\\"]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "depNameTemplate": "ghcr.io/runlix/distroless-runtime",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update pinned Debian package versions in CI tool image",
      "managerFilePatterns": [
        "/^tools\\/ci\\/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=deb depName=(?<depName>[^\\s]+) suite=(?<suite>[^\\s]+)\\nARG [A-Z_]+=(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "deb",
      "registryUrlTemplate": "https://deb.debian.org/debian?suite={{suite}}&components=main&binaryArch=amd64",
      "versioningTemplate": "deb"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "pinDigests": true,
      "automerge": false,
      "schedule": ["before 4am on Monday"],
      "commitMessageTopic": "{{depName}} GitHub Action"
    },
    {
      "matchManagers": ["custom.regex", "dockerfile"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["gcr.io/distroless/base-debian12"],
      "groupName": "Distroless Upstream Docker Images",
      "automerge": false,
      "schedule": ["before 4am on Monday"]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/runlix/distroless-runtime"],
      "groupName": "Runlix Runtime Docker Images",
      "automerge": false,
      "schedule": ["before 4am on Monday"]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["deb"],
      "matchPackageNames": ["bash", "ca-certificates", "git", "jq"],
      "groupName": "CI Tool Image Debian Packages",
      "automerge": false,
      "schedule": ["before 4am on Monday"]
    }
  ]
}
